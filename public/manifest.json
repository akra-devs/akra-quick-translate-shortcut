{
  "manifest_version": 3,
  "name": "Akra Quick Translate",
  "version": "0.1.0",
  "description": "Toggle page translation and original text restore with Chrome's built-in Translator API.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*", "file://*/*"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Toggle Akra Quick Translate"
  },
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Toggle page translation"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
